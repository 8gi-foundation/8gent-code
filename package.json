{
  "name": "@8gi-foundation/8gent-code",
  "version": "0.17.1",
  "private": false,
  "description": "Autonomous coding agent. Runs locally on Ollama. Zero API cost. Your code stays on your machine. Open source.",
  "type": "module",
  "bin": {
    "8": "./bin/8gent-run.js",
    "8gent": "./bin/8gent-run.js",
    "8gent-code": "./bin/8gent-run.js"
  },
  "files": [
    "dist/cli.js",
    "dist/tui.js",
    "dist/skills",
    "dist/sounds",
    "bin/8gent-run.js",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run packages/eight/index.ts",
    "agent": "bun run packages/eight/index.ts",
    "daemon": "bun run packages/daemon/index.ts",
    "daemon:local": "bun run packages/daemon/scripts/start-local.ts",
    "tui": "bun run apps/tui/src/index.tsx",
    "pet": "bash apps/lil-eight/build.sh && open 'apps/lil-eight/build/Lil Eight.app'",
    "pet:build": "bash apps/lil-eight/build.sh",
    "pet:open": "open 'apps/lil-eight/build/Lil Eight.app'",
    "pet:kill": "pkill -f LilEight",
    "pet:log": "tail -f ~/.8gent/lil-eight.log",
    "install-wizard": "bun run scripts/install-wizard.tsx",
    "install:apple-foundation": "bun run scripts/install-apple-foundation.ts",
    "build:eyes-bridge": "bash packages/eyes/native/build.sh",
    "cli": "bun run bin/8gent.ts",
    "dev": "next dev",
    "build": "bun build bin/8gent.ts --outfile dist/cli.js --target bun && bun build apps/tui/src/index.tsx --outfile dist/tui.js --target bun --external react-devtools-core && node scripts/build-finalize.js",
    "build:tui": "bun build apps/tui/src/index.tsx --outfile dist/tui.js --target bun --external react-devtools-core",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "test": "bun test packages/ apps/",
    "test:benchmarks": "bun test benchmarks/",
    "test:models": "bun scripts/test-models.ts",
    "test:models:providers": "bun scripts/test-models.ts --providers",
    "cua:setup": "bun run packages/eight/scripts/cua-setup.ts",
    "cua:run": "bun run packages/eight/scripts/cua-run.ts",
    "smoke": "bun scripts/smoke.ts",
    "smoke:fast": "bun scripts/smoke.ts --skip-network",
    "smoke:strict": "bun scripts/smoke.ts --strict",
    "verify:presets": "bun scripts/verify-presets.ts",
    "verify:presets:strict": "bun scripts/verify-presets.ts --strict",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:tui": "tsc --noEmit -p apps/tui/tsconfig.json",
    "check:harness": "tsc --noEmit -p tsconfig.harness.json",
    "benchmark": "bun run scripts/benchmark.ts",
    "benchmark:suite": "bun run benchmarks/runner.ts",
    "benchmark:category": "bun run benchmarks/runner.ts --category",
    "benchmark:single": "bun run benchmarks/runner.ts --bench",
    "benchmark:swebench": "bun run benchmarks/swebench/run.ts",
    "benchmark:loop": "bun run benchmarks/computer-use-bakeoff.ts",
    "benchmark:bakeoff": "bun run benchmarks/computer-use-bakeoff.ts",
    "benchmark:multi": "bun run benchmarks/autoresearch/multi-model-harness.ts",
    "audit": "bun run packages/audit/cli.ts",
    "demo": "bun run scripts/demo-savings.ts",
    "provision-tenant": "bun run scripts/provision-tenant.ts",
    "harness": "bun run packages/harness-cli/index.ts",
    "harness:run": "bun run packages/harness-cli/index.ts run",
    "harness:sessions": "bun run packages/harness-cli/index.ts sessions",
    "harness:inspect": "bun run packages/harness-cli/index.ts inspect",
    "harness:doctor": "bun run packages/harness-cli/index.ts doctor",
    "debug": "bun run bin/debug.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.5.0",
    "@changesets/cli": "^2.30.0",
    "@napi-rs/canvas": "^0.1.97",
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "bmad-method": "^6.1.0",
    "react-doctor": "^0.1.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mozilla/readability": "^0.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "jsdom": "^28.1.0",
    "miniflare": "^4.20260317.1",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "8GI Foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/8gi-foundation/8gent-code.git"
  },
  "homepage": "https://8gent.dev",
  "bugs": {
    "url": "https://github.com/8gi-foundation/8gent-code/issues"
  }
}
