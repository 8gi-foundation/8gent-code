# Both Telegram bot credentials. Real file at /etc/8gent/bots.env. Mode 600.
# The bridge picks its pair via BOT_NAME (set per service in compose).
#
#   BOT_NAME=aijames   -> reads TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID
#   BOT_NAME=eightgent -> reads EIGHT_BOT_TOKEN    + EIGHT_CHAT_ID

# @aijamesosbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# @eightgentcodebot
EIGHT_BOT_TOKEN=
EIGHT_CHAT_ID=

# Optional dev group mirror (applies to both bridges).
TELEGRAM_DEV_GROUP_ID=
