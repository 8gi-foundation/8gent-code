# Shared daemon env. Sourced by all three units.
# Real file lives at /etc/8gent/daemon.env on the box. Mode 600, root-owned.

# Daemon WebSocket gateway. Same on all three units.
DAEMON_URL=ws://localhost:18789

# Optional: shared bearer token between daemon and bridges. If set, bridges
# must present it on connect. Generate once: openssl rand -hex 32
DAEMON_AUTH_TOKEN=

# Provider config for the agent pool. The daemon resolves auto:free at startup.
DEFAULT_MODEL=auto:free
DEFAULT_RUNTIME=openrouter
OPENROUTER_API_KEY=

# Optional: voice transcription for incoming Telegram audio. First non-empty wins.
GROQ_API_KEY=
OPENAI_API_KEY=

# Where the daemon writes its data dir. Both bridges read from the same dir.
EIGHT_HOME=/var/lib/8gent
