{
  "name": "@8gent/hands",
  "version": "0.1.0",
  "private": true,
  "description": "8gent-hands v0: thin Bun wrapper around the locally-installed cua-driver MCP binary. Powers the 8gent Computer Mac app. Future home of the trycua/cua fork (see #1746).",
  "main": "index.ts",
  "types": "index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./plan": {
      "import": "./plan.ts",
      "types": "./plan.ts"
    },
    "./types": {
      "import": "./types.ts",
      "types": "./types.ts"
    }
  },
  "bin": {
    "8gent-hands": "./run.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "run": "bun run run.ts"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
