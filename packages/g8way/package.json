{
	"name": "@8gent/g8way",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Lotus-class model proxy. OpenAI-compatible HTTP gateway with Clerk JWT auth, per-tenant rate limiting, OpenRouter routing, and structured usage logging.",
	"main": "index.ts",
	"types": "index.ts",
	"bin": {
		"g8way": "./bin/g8way.ts"
	},
	"exports": {
		".": {
			"import": "./index.ts",
			"types": "./index.ts"
		},
		"./server": {
			"import": "./server.ts",
			"types": "./server.ts"
		}
	},
	"scripts": {
		"start": "bun run bin/g8way.ts",
		"dev": "bun run --watch bin/g8way.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@8gent/auth": "workspace:*",
		"hono": "^4.7.0",
		"jose": "^6.0.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.3.0"
	}
}
