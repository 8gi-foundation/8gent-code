{
	"name": "@8gent/db",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"description": "Convex client wrappers + workspace-local SQLite layer for 8gent Code. Convex schema and functions now live in 8gi-foundation/8gi-data (private).",
	"main": "client.ts",
	"types": "client.ts",
	"exports": {
		".": {
			"import": "./client.ts",
			"types": "./client.ts"
		},
		"./types": {
			"import": "./types.ts",
			"types": "./types.ts"
		},
		"./workspace": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test src/"
	},
	"dependencies": {
		"@8gi/data": "git+ssh://git@github.com:8gi-foundation/8gi-data.git#main",
		"convex": "^1.17.0"
	},
	"devDependencies": {
		"typescript": "^5.3.0"
	}
}
