{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": false,
		"noEmit": true,
		"isolatedModules": true,
		"allowJs": false,
		"types": ["bun", "node"],
		"typeRoots": ["../../node_modules/@types"],
		"lib": ["ES2022", "DOM"],
		"baseUrl": "../..",
		"paths": {
			"@8gent/eyes": ["packages/eyes/index.ts"],
			"@8gent/eyes/types": ["packages/eyes/types.ts"],
			"@8gent/hands": ["packages/hands/index.ts"]
		}
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
