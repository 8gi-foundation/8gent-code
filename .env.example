# Telegram Bot (required for notifications)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# OpenRouter (for cloud model access)
OPENROUTER_API_KEY=

# Anthropic (for Claude head-to-head competition)
ANTHROPIC_API_KEY=

# Ollama (defaults to localhost)
OLLAMA_URL=http://localhost:11434

# apfel (Apple Foundation HTTP, Chat Completions style). Apple Silicon + macOS 26 Tahoe+.
# Default port collides with Ollama. Run apfel on 11500 to keep Ollama on 11434.
APFEL_BASE_URL=http://localhost:11500/v1

# DeepSeek (heavy cloud fallback for the computer channel)
DEEPSEEK_API_KEY=
# Set DEEPSEEK_USE_PRO=1 to switch to V4-Pro (default V4-Flash).
DEEPSEEK_USE_PRO=

# Failover event logging - set to 1 to emit machine-parseable lines on stderr.
FAILOVER_LOG=

# Wave 4 B-2: tenant provisioning (scripts/provision-tenant.ts).
# All values are optional in dry-run mode; required only when running with --apply.
HETZNER_BOX_IP=78.47.98.218
HETZNER_DNS_API_TOKEN=
HETZNER_S3_ACCESS_KEY=
HETZNER_S3_SECRET_KEY=
HETZNER_S3_REGION=fsn1
CLERK_SECRET_KEY=
CLERK_FOUNDATION_USER_ID=
NEXT_PUBLIC_CONVEX_URL=
VESSEL_CONVEX_SERVICE_KEY=
BOARD_CHAIR=James Spalding
